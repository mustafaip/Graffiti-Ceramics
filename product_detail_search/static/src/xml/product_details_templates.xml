<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
    <t t-name="product_detail_search.ProductDetails" owl="1">
       <div class="clientlist-screen screen">
           <div class="screen-content">

               <h2 style="text-align: center;
                    font-size: 28px;
                    margin-bottom: 10pxpx;
                    margin-top: 1px;">Product Information</h2>
               <!-- Empty state when no product details are returned. -->
               <t t-if="product_details==false">
                   <h2 style="display: flex;justify-content: center;">No products Found</h2>
               </t>
               <t t-else="">
                   <!-- Core product detail layout with image and metadata table. -->
                   <div class="container_product_info">
                        <div class="category-img">
                            <img t-attf-src="/web/image?model=product.product&amp;field=image_1920&amp;id=#{product_details[0].id}"/>
                        </div>
                       <div style="width: fit-content;">
                            <table style="margin: 0 auto;
                            table-layout: fixed;width: auto;font-size:16px; margin: revert;">
                                <tr>
                                    <td class="label">Product Name:</td>
                                    <td class="value"
                                        t-esc="product_details[0].name"/>
                                </tr>
                                <tr>
                                    <td class="label">Product Specification:
                                    </td>
                                    <td class="value"
                                        t-esc="product_details[0].specification"/>
                                </tr>
                                <tr>
                                    <td class="label">Product Type:
                                    </td>
                                    <td class="value"
                                        t-esc="product_details[0].type"/>
                                </tr>
                                <t>
                                    <tr>
                                        <td class="label">Product Tax:
                                        </td>
                                        <td class="value"
                                            t-esc="product_details[0].tax_amount"/>
                                    </tr>
                                </t>
                                <tr>
                                    <td class="label">Barcode:</td>
                                    <td class="value"
                                        t-esc="product_details[0].barcode"/>
                                </tr>
                                <tr>
                                    <td class="label">Code:</td>
                                    <t t-if="product_details[0].default_code">
                                    <td class="value"
                                        t-esc="product_details[0].default_code"/>
                                    </t>
                                    <t t-else="">
                                        <td class="value">No code</td>
                                    </t>
                                </tr>

                                <tr>
                                    <td class="label">Product Category:</td>
                                    <td class="value"
                                        t-esc="product_details[0].category"/>
                                </tr>
                                <tr>
                                    <td class="label">Available Stock:</td>
                                    <td class="value"
                                        t-esc="product_details[0].qty_available"/>
                                </tr>
                                <tr>
                                    <td class="label">Sales Price:</td>
                                    <td class="value">
                                        <span style="display: inline-flex; align-items: baseline; gap: 6px; white-space: nowrap;">
                                            <span t-esc="product_details[0].symbol"/>
                                            <span t-esc="product_details[0].list_price"/>
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="label">Company:</td>
                                    <t t-if="product_details[0].company_id==false">
                                            <td class="value"
                                                style="padding-left: 0px;">No company</td>
                                    </t>
                                    <t t-else="">
                                        <td class="value"
                                            t-esc="product_details[0].company_id[1]"/>
                                    </t>
                                </tr>
                            </table>
                       </div>
                   </div>
               </t>
           </div>
       </div>
   </t>
</templates>
