<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="FindProductChrome"
       t-inherit="point_of_sale.Navbar"
       t-inherit-mode="extension"
       owl="1">

        <!-- Add a Find Product shortcut button to the POS navbar. -->
        <xpath expr="//div[hasclass('status-buttons')]/button" position="after">
            <button
                class="btn btn-secondary d-flex align-items-center gap-1"
                type="button"
                title="Find Product"
                t-on-click="find_product"
            >
                <i class="fa fa-product-hunt"/>
                <span>Find Product</span>
            </button>
        </xpath>

    </t>
</templates>




