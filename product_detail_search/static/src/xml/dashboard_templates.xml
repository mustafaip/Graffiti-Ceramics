<?xml version="1.0" encoding="utf-8" ?>
<template>
    <t t-name="CustomDashBoardFindProduct">
        <!-- Wraps the barcode search dashboard in the standard Odoo container. -->
        <div class="oh_dashboards container"
             style="margin-top: 20px;">
            <div style="display:flex;"
                 class="container-fluid o_pj_dashboard barcode_inventory">
                <t t-call="product_detail_search_template"/>
            </div>
        </div>
    </t>
    <t t-name="product_detail_search_template">
        <!-- Barcode input and dynamic product details display. -->
        <header>
            <div class="barcode_scan">
                <h2>Scan Your Barcode</h2>
                <input type="text" id="barcode" name="barcode"
                       style="border-radius:7px;"
                       t-on-change="(e) => this.change_product_barcode(e)"
                       t-on-keypress="(e) => this.onProductKeypress(e)"
                       placeholder="Please Scan your barcode"/>
            </div>
            <t t-if="state.barcode_value">
                <!-- If a barcode is entered but no product is found, show the empty state. -->
                <t t-if="state.product_details==false">
                    <h1 style="margin:100px">No Product Found</h1>
                </t>
                <t t-else="">
                    <!-- Product information panel populated from backend data. -->
                    <div class="clientlist-screen screen">
                        <div class="screen-content barcode_screen">
                            <h1>Product Information</h1>
                            <div class="container_product_info">
                                <div class="category-img">
                                    <img style="width:300px;height:300px"
                                         t-attf-src="/web/image?model=product.product&amp;field=image_1920&amp;id=#{state.product_details[0].id}"/>
                                </div>
                                <div class="container-fluid" style="
                                display: flex;
                                 justify-content: center;">
                                    <table style="margin: 0 auto;
                                        table-layout: fixed;
                                        width: auto;font-size: 14px;">
                                        <tr>
                                            <td class="label">Product Name:
                                            </td>
                                            <td class="value"
                                                t-esc="state.product_details[0].name"/>
                                        </tr>
                                        <tr>
                                            <td class="label">Product
                                                Specification:
                                            </td>
                                            <td class="value"
                                                t-esc="state.product_details[0].specification"/>
                                        </tr>
                                        <tr>
                                            <td class="label">Product Type:
                                            </td>
                                            <td class="value"
                                                t-esc="state.product_details[0].type"/>
                                        </tr>
                                        <t t-if="state.product_details[0].taxes_id">
                                            <tr>
                                                <td class="label">Product Tax:
                                                </td>
                                                <td class="value"
                                                    t-esc="state.product_details[0].tax_amount"/>
                                            </tr>
                                        </t>
                                        <tr>
                                            <td class="label">Barcode:</td>
                                            <td class="value"
                                                t-esc="state.product_details[0].barcode"/>
                                        </tr>
                                        <tr>
                                            <td class="label">Code:</td>
                                            <t t-if="state.product_details[0].default_code">
                                                <td class="value"
                                                    t-esc="state.product_details[0].default_code"/>
                                            </t>
                                            <t t-else="">
                                                <td class="value">No code</td>
                                            </t>
                                        </tr>
                                        <tr>
                                            <td class="label">Product
                                                Category:
                                            </td>
                                            <td class="value"
                                                t-esc="state.product_details[0].category"/>
                                        </tr>
                                        <tr>
                                            <td class="label">Available
                                                Stock:
                                            </td>
                                            <td class="value"
                                                t-esc="state.product_details[0].qty_available"/>
                                        </tr>
                                        <tr>
                                            <td class="label">Sales Price:</td>
                                            <td class="value">
                                                <span style="display: inline-flex; align-items: baseline; gap: 6px; white-space: nowrap;">
                                                    <span t-esc="state.product_details[0].symbol"/>
                                                    <span t-esc="state.product_details[0].list_price"/>
                                                </span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="label">Company:</td>
                                            <t t-if="state.product_details[0].company_id==false">
                                                <td class="value">No company
                                                </td>
                                            </t>
                                            <t t-else="">
                                                <td class="value"
                                                    t-esc="state.product_details[0].company_id[1]"/>
                                            </t>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </header>
    </t>
</template>
