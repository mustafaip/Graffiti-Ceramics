<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="product_detail_search.FindProductDialog" owl="1">
        <!-- Fullscreen dialog used to scan and display product details. -->
        <Dialog title="'Find Product'" size="'fullscreen'">

            <main class="body">
                <!-- Show details when available; otherwise prompt to scan. -->
                <t t-if="state.product_details">
                    <div class="order-button floor-button d-flex align-items-center gap-2 px-4 fw-bolder cursor-pointer" t-on-click="back">
                       <i class="fa fa-2x fa-angle-left pb-1" role="img"
                          aria-label="Go Back" title="Go Back"/>
                        <span>Back</span>
                    </div>
                    <ProductDetails product_details="state.product_details"/>
                </t>
                <t t-else="">
                    <div class="d-flex flex-column align-items-center justify-content-center"
                         style="min-height: 250px;">

                        <h2 class="mb-2 fw-bold">
                            Scan Your Product
                        </h2>

                        <h4 class="text-muted">
                            Please scan a product to get the details
                        </h4>

                    </div>
                </t>

            </main>

            <t t-set-slot="footer">
                <button class="btn btn-secondary" t-on-click="close">
                    Close
                </button>
            </t>

        </Dialog>
    </t>

</templates>
