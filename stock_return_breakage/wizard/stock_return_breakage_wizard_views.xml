<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_return_breakage_wizard_form" model="ir.ui.view">
        <field name="name">stock.return.breakage.wizard.form</field>
        <field name="model">stock.return.breakage.wizard</field>
        <field name="arch" type="xml">
            <form string="Return with Breakage">
                <sheet>
                    <div class="oe_title">
                        <h1>Return with Breakage</h1>
                        <h3 class="text-muted">
                            <field name="picking_id" readonly="1"/>
                        </h3>
                    </div>

                    <group string="Accounting Configuration" col="2">
                        <field name="inventory_journal_id" required="1"/>
                        <field name="expense_journal_id" required="1"/>
                        <field name="expense_account_id" required="1"/>
                    </group>

                    <notebook>
                        <page string="Products to Return">
                            <field name="line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="product_id" readonly="1"/>
                                    <field name="done_qty" readonly="1" string="Delivered Qty"/>
                                    <field name="quantity" string="Return Qty"/>
                                    <field name="product_uom_id" readonly="1"/>
                                    <field name="unit_cost" string="Unit Cost (for JE)"/>
                                    <field name="move_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" placeholder="Reason for breakage return…" nolabel="1"/>
                        </page>
                    </notebook>

                    <div class="alert alert-warning" role="alert" style="margin-top: 12px;">
                        <strong>What this will do:</strong>
                        <ul style="margin-bottom: 0;">
                            <li>Create a <strong>reverse delivery (return)</strong> to reduce stock.</li>
                            <li>Post a <strong>journal entry</strong>: debit the Damage Expense Account,
                                credit the Stock Valuation Account (from the product category).</li>
                        </ul>
                    </div>
                </sheet>
                <footer>
                    <button name="action_confirm"
                            string="Confirm Return &amp; Post Entry"
                            type="object"
                            class="btn-primary"
                            data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_stock_return_breakage_wizard" model="ir.actions.act_window">
        <field name="name">Return with Breakage</field>
        <field name="res_model">stock.return.breakage.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
