<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_picking_form_breakage" model="ir.ui.view">
        <field name="name">stock.picking.form.breakage</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">

            <!-- "Return with Breakage" button – visible only on done outgoing pickings -->
            <xpath expr="//button[@name='action_cancel']" position="before">
                <button name="action_open_breakage_wizard"
                        string="Return with Breakage"
                        type="object"
                        class="btn-warning"
                        icon="fa-exclamation-triangle"
                        invisible="state != 'done' or picking_type_code != 'outgoing'"
                        groups="stock.group_stock_user"/>
            </xpath>

            <!-- Smart buttons -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_breakage_returns"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-rotate-left"
                        invisible="breakage_count == 0">
                    <field name="breakage_count" widget="statinfo" string="Breakage Returns"/>
                </button>
                <button name="action_view_breakage_journal_entries"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-book"
                        invisible="breakage_journal_count == 0">
                    <field name="breakage_journal_count" widget="statinfo" string="Damage Entries"/>
                </button>
            </xpath>

        </field>
    </record>
</odoo>
