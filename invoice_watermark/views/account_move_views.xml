<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_form_watermark" model="ir.ui.view">
        <field name="name">account.move.form.watermark</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='invoice_date_due']" position="after">
                <label for="payment_watermark"
                       string="PDF Watermark"
                       invisible="move_type != 'out_invoice'"/>
                <field
                    name="payment_watermark"
                    widget="selection"
                    invisible="move_type != 'out_invoice'"
                    options="{'no_open': True}"
                />
            </xpath>

        </field>
    </record>

</odoo>
