<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Inherit the standard customer invoice form view to inject the
        payment_watermark selection field.

        The field is placed in the "other info" tab so it does not clutter
        the main invoice layout, but is still easy to find.
        It is hidden automatically for all move types that are NOT
        customer invoices (out_invoice).
    -->
    <record id="view_move_form_watermark" model="ir.ui.view">
        <field name="name">account.move.form.watermark</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!--
                Insert just after the "payment_reference" field that already
                lives in the top-right column of the invoice header.
                This keeps the watermark choice visible without opening a tab.
            -->
            <xpath expr="//field[@name='invoice_date_due']" position="after">
                <field
                    name="payment_watermark"
                    widget="selection"
                    string="Print Watermark"
                    invisible="move_type != 'out_invoice'"
                    options="{'no_open': True}"
                />
            </xpath>

        </field>
    </record>

</odoo>
