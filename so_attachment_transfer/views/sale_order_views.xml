<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sale_order_form_design_docs" model="ir.ui.view">
        <field name="name">sale.order.form.design.docs</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_view_so_design_docs"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-paperclip"
                >
                    <field
                        name="so_design_doc_count"
                        widget="statinfo"
                        string="Design Documents"
                    />
                </button>
            </xpath>

        </field>
    </record>

</odoo>
