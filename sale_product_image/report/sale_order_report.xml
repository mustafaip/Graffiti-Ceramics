<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Inherits the sale order report template to add the image of the product in the report-->
    <template id="report_saleorder_inherit"
              inherit_id="sale.report_saleorder_document">
        <xpath expr="//table//tr/th[1]" position="after">
            <t t-if="request.env['ir.config_parameter'].sudo().get_param('sale_product_image.is_show_product_image_in_sale_report')">
                <th>
                    <strong>Image</strong>
                </th>
            </t>
        </xpath>
        <xpath expr="//t[@t-foreach='lines_to_report']//td[@name='td_product_name']" position="after">
            <t t-if="request.env['ir.config_parameter'].sudo().get_param('sale_product_image.is_show_product_image_in_sale_report')">
                <td style="width: 100px; padding: 0;">
                    <table cellpadding="5" cellspacing="0" border="0" style="background: white; width: 100%;">
                        <tr>
                            <td style="background: white; border: 5px solid white;">
                                <img t-if="line.image_for_report"
                                     t-att-src="image_data_uri(line.image_for_report)"
                                     style="max-height: 80px; max-width: 80px; display: block;"
                                     alt=""/>
                            </td>
                        </tr>
                    </table>
                </td>
            </t>
        </xpath>
    </template>
</odoo>
