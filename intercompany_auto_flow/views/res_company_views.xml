<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Company Form: Intercompany Auto Flow tab ──────────────────────── -->
    <record id="view_company_form_intercompany_flow" model="ir.ui.view">
        <field name="name">res.company.form.intercompany.flow</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Intercompany Auto Flow" name="intercompany_auto_flow">
                    <group string="General">
                        <field name="intercompany_auto_flow"
                               widget="boolean_toggle"/>
                    </group>
                    <group invisible="not intercompany_auto_flow">
                        <group string="Automation">
                            <field name="intercompany_sale_auto_confirm"
                                   widget="boolean_toggle"/>
                            <field name="intercompany_purchase_auto_confirm"
                                   widget="boolean_toggle"/>
                            <field name="intercompany_auto_validate_pickings"
                                   widget="boolean_toggle"/>
                            <field name="intercompany_auto_invoice"
                                   widget="boolean_toggle"/>
                        </group>
                        <group string="Supplier Search">
                            <field name="intercompany_search_all_companies"
                                   widget="boolean_toggle"/>
                            <field name="intercompany_allowed_company_ids"
                                   widget="many2many_tags"
                                   invisible="intercompany_search_all_companies"/>
                            <field name="intercompany_partner_id"/>
                            <field name="intercompany_stock_route_id"/>
                        </group>
                    </group>
                    <div invisible="not intercompany_auto_flow">
                        <div class="alert alert-info" role="alert">
                            <strong>How it works:</strong>
                            When this company confirms a Sale Order for a product
                            with insufficient local stock, the module will:
                            <ol>
                                <li>Search sibling companies for available stock.</li>
                                <li>Create a <b>Purchase Order</b> in <em>this</em> company
                                    at the product's <b>cost price</b>.</li>
                                <li>Create a <b>Sales Order</b> in the <em>supplying</em>
                                    company at the product's <b>cost price</b>.</li>
                                <li>Confirm both documents automatically.</li>
                                <li>If <b>Auto-Validate Stock Moves</b> is enabled:
                                    validate the delivery and receipt immediately.</li>
                                <li>If <b>Auto-Create Bills &amp; Invoices</b> is enabled:
                                    post a vendor bill in this company and a customer
                                    invoice in the supplying company automatically.</li>
                            </ol>
                            All sibling companies participating must also have
                            <b>Intercompany Auto Flow enabled</b>.
                        </div>
                    </div>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
